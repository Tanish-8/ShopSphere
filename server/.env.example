# ===========================================================================
# ShopSphere — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ===========================================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas ---
# Option A (recommended): SRV connection string (from Atlas → Connect → Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/shopsphere?retryWrites=true&w=majority&appName=ShopSphere

# Option B: Standard connection string (use this if SRV/DNS fails on your network)
# Find this in Atlas → Connect → Drivers → toggle "SRV" off
# MONGO_URI=mongodb://<username>:<password>@<shard0>,<shard1>,<shard2>/<dbname>?ssl=true&replicaSet=atlas-xxxx-shard-0&authSource=admin&retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# --- Frontend URL (for CORS) ---
CLIENT_URL=http://localhost:5173
